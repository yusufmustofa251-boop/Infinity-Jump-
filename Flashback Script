local maxHistory = 300           -- maksimal 300 frame (sekitar 5 detik jika 60fps)
local recordInterval = 0.05     -- interval rekam (detik)
local flashbackSpeed = 0.03     -- kecepatan mundur (detik antar posisi)
local flashbackIndex = 1         -- index posisi saat flashback

