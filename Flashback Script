-- ================= FUNGSI =================
local function recordPosition()
    while recording do
        task.wait(recordInterval)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            table.insert(positionHistory, root.CFrame)
            if #positionHistory > maxHistory then
                table.remove(positionHistory, 1)
            end
        end
    end
end

local function startFlashback()
    if flashbackActive then return end
    if #positionHistory == 0 then
        StarterGui:SetCore("SendNotification", { Title = "Flashback", Text = "Tidak ada posisi yang direkam!", Duration = 2 })
        return
    end
    flashbackActive = true
    recording = false
    statusLabel.Text = "Status: Flashback"
    statusLabel.TextColor3 = Color3.new(255,255,0)

    flashbackIndex = #positionHistory
    local function flashbackLoop()
        while flashbackActive and flashbackIndex > 1 do
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                root.CFrame = positionHistory[flashbackIndex]
            end
            flashbackIndex = flashbackIndex - 1
            task.wait(flashbackSpeed)
        end
        if flashbackIndex <= 1 then
            stopFlashback()
        end
    end
    task.spawn(flashbackLoop)
end

local function stopFlashback()
    flashbackActive = false
    recording = true
    statusLabel.Text = "Status: Recording"
    statusLabel.TextColor3 = Color3.new(0,255,0)
    -- Kosongkan history setelah flashback selesai? Opsi: tetap simpan atau reset? Biarkan tetap ada.
end

local function resetFlashback()
    stopFlashback()
    positionHistory = {}
    flashbackIndex = 1
    StarterGui:SetCore("SendNotification", { Title = "Flashback", Text = "Riwayat posisi direset", Duration = 2 })
end

-- ================= TOMBOL =================
stopBtn.MouseButton1Click:Connect(function()
    if flashbackActive then
        stopFlashback()
    else
        startFlashback()
    end
end)

resetBtn.MouseButton1Click:Connect(function()
    resetFlashback()
end)

-- Mulai rekaman
task.spawn(recordPosition)

print("✅ Flashback script loaded")
