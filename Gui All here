local player = game.Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")

-- GUI
local gui = Instance.new("ScreenGui", player.PlayerGui)
local btn = Instance.new("TextButton", gui)

btn.Size = UDim2.new(0,150,0,50)
btn.Position = UDim2.new(0,20,0,100)
btn.Text = "DEWA MODE: OFF"
btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
btn.TextColor3 = Color3.new(1,1,1)

-- STATE
local fly = false
local boost = false

-- VAR
local bodyVel, bodyGyro
local tilt = 0
local cam = workspace.CurrentCamera

-- GET CHAR
local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

-- TRAIL
local function addTrail(part)
    local att0 = Instance.new("Attachment", part)
    local att1 = Instance.new("Attachment", part)

    att0.Position = Vector3.new(0,1,0)
    att1.Position = Vector3.new(0,-1,0)

    local trail = Instance.new("Trail")
    trail.Attachment0 = att0
    trail.Attachment1 = att1
    trail.Lifetime = 0.3
    trail.Parent = part
end

-- TOGGLE
btn.MouseButton1Click:Connect(function()
    fly = not fly
    btn.Text = "DEWA MODE: " .. (fly and "ON" or "OFF")

    local char = getChar()
    local hrp = char:WaitForChild("HumanoidRootPart")

    if fly then
        bodyVel = Instance.new("BodyVelocity", hrp)
        bodyVel.MaxForce = Vector3.new(1e5,1e5,1e5)

        bodyGyro = Instance.new("BodyGyro", hrp)
        bodyGyro.MaxTorque = Vector3.new(1e5,1e5,1e5)

        -- TRAIL
        if char:FindFirstChild("Left Leg") then
            addTrail(char["Left Leg"])
            addTrail(char["Right Leg"])
        end

        -- AURA
        local aura = Instance.new("ParticleEmitter")
        aura.Texture = "rbxassetid://243660364"
        aura.Rate = 15
        aura.Speed = NumberRange.new(2,4)
        aura.Parent = hrp
    else
        if bodyVel then bodyVel:Destroy() end
        if bodyGyro then bodyGyro:Destroy() end
    end
end)

-- BOOST INPUT
UIS.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch 
    or input.KeyCode == Enum.KeyCode.LeftShift then
        boost = true
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch 
    or input.KeyCode == Enum.KeyCode.LeftShift then
        boost = false
    end
end)

-- MAIN LOOP
RunService.RenderStepped:Connect(function(dt)
    if fly and bodyVel and bodyGyro then
        local char = getChar()
        local hrp = char:FindFirstChild("HumanoidRootPart")

        local moveDir = Vector3.new(0,0,0)

        if UIS:IsKeyDown(Enum.KeyCode.W) then
            moveDir = moveDir + cam.CFrame.LookVector
        end
        if UIS:IsKeyDown(Enum.KeyCode.S) then
            moveDir = moveDir - cam.CFrame.LookVector
        end
        if UIS:IsKeyDown(Enum.KeyCode.A) then
            moveDir = moveDir - cam.CFrame.RightVector
        end
        if UIS:IsKeyDown(Enum.KeyCode.D) then
            moveDir = moveDir + cam.CFrame.RightVector
        end

        local speed = boost and 120 or 60
        bodyVel.Velocity = moveDir * speed

        -- SMOOTH POSE
        if moveDir.Magnitude > 0 then
            tilt = tilt + dt * 5
            local wave = math.sin(tilt) * 5

            local target = CFrame.new(hrp.Position, hrp.Position + moveDir)
                * CFrame.Angles(math.rad(-90 + wave),0,0)

            bodyGyro.CFrame = bodyGyro.CFrame:Lerp(target,0.15)
        end

        -- BOOST EFFECT
        if boost then
            local p = Instance.new("Part")
            p.Size = Vector3.new(1,1,1)
            p.CFrame = hrp.CFrame
            p.Anchored = true
            p.CanCollide = false
            p.Transparency = 0.5
            p.Parent = workspace
            Debris:AddItem(p,0.3)
        end

        -- CAMERA FOV
        local targetFOV = boost and 90 or 70
        cam.FieldOfView = cam.FieldOfView + (targetFOV - cam.FieldOfView) * 0.1
    end
end)
