local downBtn = Instance.new("TextButton", frame)
downBtn.Size = UDim2.new(0.4,0,0,35)
downBtn.Position = UDim2.new(0.55,0,0,260)
downBtn.Text = "⬇️"
downBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)

-- SPEED
local speedBtn = Instance.new("TextButton", frame)
speedBtn.Size = UDim2.new(1,-20,0,35)
speedBtn.Position = UDim2.new(0,10,0,310)
speedBtn.Text = "Speed: 60"
speedBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)

-- STATE VARIABLES
local fly, invis, infJump, god = false,false,false,false
local flySpeed = 60
local goingUp, goingDown = false,false
local bodyVel, bodyGyro

-- UP/DOWN LOGIC
upBtn.MouseButton1Down:Connect(function() goingUp = true end)
upBtn.MouseButton1Up:Connect(function() goingUp = false end)
downBtn.MouseButton1Down:Connect(function() goingDown = true end)
downBtn.MouseButton1Up:Connect(function() goingDown = false end)

-- SPEED LOGIC
speedBtn.MouseButton1Click:Connect(function()
    flySpeed += 20
    if flySpeed > 200 then flySpeed = 40 end
    speedBtn.Text = "Speed: "..flySpeed
end)

-- MAIN LOOP
RunService.RenderStepped:Connect(function()
    fly = flyToggle.Get()
    invis = invisToggle.Get()
    infJump = jumpToggle.Get()
    god = godToggle.Get()

    local char = getChar()
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local cam = workspace.CurrentCamera

    -- GOD MODE
    if god then
        flyToggle.Set(true)
        invisToggle.Set(true)
        jumpToggle.Set(true)
    end

    -- FLY SYSTEM
    if fly then
        hum.PlatformStand = true
        if not bodyVel then
            bodyVel = Instance.new("BodyVelocity", hrp)
            bodyVel.MaxForce = Vector3.new(1e5,1e5,1e5)

            bodyGyro = Instance.new("BodyGyro", hrp)
            bodyGyro.MaxTorque = Vector3.new(1e5,1e5,1e5)
        end

        local moveDir = hum.MoveDirection
        local dir = (cam.CFrame.LookVector * moveDir.Z + cam.CFrame.RightVector * moveDir.X)
        if goingUp then dir += Vector3.new(0,1,0) end
        if goingDown then dir -= Vector3.new(0,1,0) end
        if dir.Magnitude > 0 then dir = dir.Unit end

        bodyVel.Velocity = dir * flySpeed
        bodyGyro.CFrame = CFrame.new(hrp.Position, hrp.Position + cam.CFrame.LookVector)
    else
        hum.PlatformStand = false
        if bodyVel then bodyVel:Destroy() bodyVel=nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro=nil end
    end

    -- INVISIBLE
    for _,v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Transparency = invis and 1 or 0
        end
    end
end)

-- INFINITE JUMP
UIS.JumpRequest:Connect(function()
    if jumpToggle.Get() then
        local hum = getChar():FindFirstChildOfClass("Humanoid")
        if hum then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

