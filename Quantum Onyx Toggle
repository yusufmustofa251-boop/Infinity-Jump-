-- DELTA-STYLE TOGGLE FUNCTION
local function makeToggle(text, y)
    local holder = Instance.new("Frame", frame)
    holder.Size = UDim2.new(1,-20,0,40)
    holder.Position = UDim2.new(0,10,0,y)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", holder)
    label.Size = UDim2.new(0.6,0,1,0)
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextScaled = true

    local toggle = Instance.new("Frame", holder)
    toggle.Size = UDim2.new(0,50,0,25)
    toggle.Position = UDim2.new(1,-60,0.5,-12)
    toggle.BackgroundColor3 = Color3.fromRGB(60,60,60)

    local circle = Instance.new("Frame", toggle)
    circle.Size = UDim2.new(0,20,0,20)
    circle.Position = UDim2.new(0,3,0.5,-10)
    circle.BackgroundColor3 = Color3.fromRGB(200,200,200)

    local state = false

    local function setToggle(on)
        state = on
        local goalPos = on and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)
        local goalColor = on and Color3.fromRGB(0,170,255) or Color3.fromRGB(200,200,200)

        TweenService:Create(circle, TweenInfo.new(0.2), {Position = goalPos, BackgroundColor3 = goalColor}):Play()
        toggle.BackgroundColor3 = on and Color3.fromRGB(0,80,120) or Color3.fromRGB(60,60,60)
    end

    holder.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            setToggle(not state)
        end
    end)

    return {
        Set = setToggle,
        Get = function() return state end
    }
end

-- TOGGLES
local flyToggle = makeToggle("Fly",50)
local invisToggle = makeToggle("Invisible",100)
local jumpToggle = makeToggle("Infinite Jump",150)
local godToggle = makeToggle("GOD MODE",200)

-- UP/DOWN BUTTONS
local upBtn = Instance.new("TextButton", frame)
upBtn.Size = UDim2.new(0.4,0,0,35)
upBtn.Position = UDim2.new(0.05,0,0,260)
upBtn.Text = "⬆️"
