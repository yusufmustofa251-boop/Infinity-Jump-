local player = game.Players.LocalPlayer

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 300, 0, 230)
frame.Position = UDim2.new(0.5, -150, 0.5, -115)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)

Instance.new("UICorner", frame).CornerRadius = UDim.new(0,10)

-- TITLE BAR
local titleBar = Instance.new("Frame", frame)
titleBar.Size = UDim2.new(1,0,0,30)
titleBar.BackgroundColor3 = Color3.fromRGB(35,35,35)
Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0,10)

-- CLOSE
local close = Instance.new("TextButton", titleBar)
close.Size = UDim2.new(0,24,0,24)
close.Position = UDim2.new(1,-30,0.5,-12)
close.BackgroundColor3 = Color3.fromRGB(255,60,60)
close.Text = ""
Instance.new("UICorner", close).CornerRadius = UDim.new(1,0)

close.MouseButton1Click:Connect(function()
    gui.Enabled = false
end)

-- DRAG
local dragging, dragStart, startPos
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- 🔑 LOGIN UI
local box = Instance.new("TextBox", frame)
box.Size = UDim2.new(0.7,0,0.25,0)
box.Position = UDim2.new(0.15,0,0.4,0)
box.PlaceholderText = "TYPE ONYX ONLY"
box.BackgroundColor3 = Color3.fromRGB(40,40,40)
box.TextColor3 = Color3.fromRGB(255,255,255)
box.TextScaled = true
box.TextXAlignment = Enum.TextXAlignment.Center
box.TextYAlignment = Enum.TextYAlignment.Center
Instance.new("UICorner", box)

local login = Instance.new("TextButton", frame)
login.Size = UDim2.new(0.5,0,0.2,0)
login.Position = UDim2.new(0.2,0,0.7,0)
login.Text = "LOGIN"
login.BackgroundColor3 = Color3.fromRGB(0,170,255)
login.TextColor3 = Color3.fromRGB(255,255,255)
login.TextScaled = true
Instance.new("UICorner", login)

-- MENU
local function loadMenu()
    for _,v in pairs(frame:GetChildren()) do
        if v ~= titleBar then v:Destroy() end
    end

    -- TAB BUTTONS
    local mainTab = Instance.new("TextButton", frame)
    mainTab.Size = UDim2.new(0.4,0,0.15,0)
    mainTab.Position = UDim2.new(0.1,0,0.2,0)
    mainTab.Text = "Main"

    local funTab = Instance.new("TextButton", frame)
    funTab.Size = UDim2.new(0.4,0,0.15,0)
    funTab.Position = UDim2.new(0.5,0,0.2,0)
    funTab.Text = "Fun"

    local container = Instance.new("Frame", frame)
    container.Size = UDim2.new(1,0,0.6,0)
    container.Position = UDim2.new(0,0,0.4,0)
    container.BackgroundTransparency = 1

    local function clear()
        for _,v in pairs(container:GetChildren()) do
            v:Destroy()
        end
    end

    local function makeBtn(text, y)
        local b = Instance.new("TextButton", container)
        b.Size = UDim2.new(0.8,0,0.18,0)
        b.Position = UDim2.new(0.1,0,y,0)
        b.Text = text
        b.BackgroundColor3 = Color3.fromRGB(60,60,60)
        Instance.new("UICorner", b)
        return b
    end

    -- STATES
    local god, jump, fly, invisible = false,false,false,false
    local speed = 16
    local savedPos = nil

    -- MAIN TAB
    local function loadMain()
        clear()

        local godBtn = makeBtn("God OFF", 0)
        godBtn.MouseButton1Click:Connect(function()
            god = not god
            godBtn.Text = "God: "..(god and "ON" or "OFF")
        end)

        game:GetService("RunService").Heartbeat:Connect(function()
            if god then
                local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum.Health = hum.MaxHealth end
            end
        end)

        local speedBtn = makeBtn("Speed: 16", 0.2)
        speedBtn.MouseButton1Click:Connect(function()
            speed += 5
            if speed > 100 then speed = 16 end
            speedBtn.Text = "Speed: "..speed

            local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = speed end
        end)

        local jumpBtn = makeBtn("Jump OFF", 0.4)
        jumpBtn.MouseButton1Click:Connect(function()
            jump = not jump
            jumpBtn.Text = "Jump: "..(jump and "ON" or "OFF")
        end)

        game:GetService("UserInputService").JumpRequest:Connect(function()
            if jump then
                local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum:ChangeState("Jumping") end
            end
        end)

        local flyBtn = makeBtn("Fly OFF", 0.6)
        flyBtn.MouseButton1Click:Connect(function()
            fly = not fly
            flyBtn.Text = "Fly: "..(fly and "ON" or "OFF")

            local char = player.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart")

            if fly then
                local bv = Instance.new("BodyVelocity", root)
                bv.Name = "FlyForce"
                bv.Velocity = Vector3.new(0,50,0)
                bv.MaxForce = Vector3.new(9999,9999,9999)
            else
                local f = root:FindFirstChild("FlyForce")
                if f then f:Destroy() end
            end
        end)

        local invisBtn = makeBtn("Invisible OFF", 0.8)
        invisBtn.MouseButton1Click:Connect(function()
            invisible = not invisible
            invisBtn.Text = "Invisible: "..(invisible and "ON" or "OFF")

            local char = player.Character
            if char then
                for _,v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.Transparency = invisible and 1 or 0
                    end
                end
            end
        end)
    end

    -- FUN TAB
    local function loadFun()
        clear()

        local saveBtn = makeBtn("Save Checkpoint", 0.1)
        saveBtn.MouseButton1Click:Connect(function()
            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                savedPos = char.HumanoidRootPart.CFrame
                saveBtn.Text = "Saved ✅"
                task.wait(1)
                saveBtn.Text = "Save Checkpoint"
            end
        end)

        local loadBtn = makeBtn("Load Checkpoint", 0.4)
        loadBtn.MouseButton1Click:Connect(function()
            local char = player.Character
            if savedPos and char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = savedPos
            else
                loadBtn.Text = "No Save ❌"
                task.wait(1)
                loadBtn.Text = "Load Checkpoint"
            end
        end)
    end

    mainTab.MouseButton1Click:Connect(loadMain)
    funTab.MouseButton1Click:Connect(loadFun)

    loadMain()
end

-- LOGIN CLICK
login.MouseButton1Click:Connect(function()
    loadMenu()
end)
