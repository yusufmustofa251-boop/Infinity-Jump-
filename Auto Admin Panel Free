end

-- Fungsi kick player
local function kickPlayer(targetPlayer, reason)
    reason = reason or "Kicked by Admin"
    
    -- Method 1: Teleport ke game lain
    pcall(function()
        TeleportService:Teleport(6403373529, targetPlayer) -- Game ID testing
    end)
    
    -- Method 2: Remote event kick
    pcall(function()
        local args = {
            [1] = targetPlayer,
            [2] = reason
        }
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("KickEvent") or
                      game:GetService("ReplicatedStorage"):FindFirstChild("KickPlayer") or
                      game:GetService("ReplicatedStorage"):FindFirstChild("AdminKick")
        if remote then
            remote:FireServer(unpack(args))
        end
    end)
    
    -- Method 3: Force character removal
    pcall(function()
        if targetPlayer.Character then
            targetPlayer.Character:BreakJoints()
        end
    end)
    
    print(string.format("[ADMIN] %s kicked %s | Reason: %s", 
        LocalPlayer.Name, targetPlayer.Name, reason))
end

-- Fungsi ban (session)
local function banPlayer(targetPlayer, reason)
    reason = reason or "Banned by Admin"
    BannedPlayers[targetPlayer.Name] = {
        userId = targetPlayer.UserId,
        reason = reason,
        time = os.time()
    }
    kickPlayer(targetPlayer, reason)
    print(string.format("[ADMIN] %s banned %s (session) | Reason: %s", 
        LocalPlayer.Name, targetPlayer.Name, reason))
end

