-- Fungsi freeze player
local function freezePlayer(targetPlayer, freeze)
    pcall(function()
        if targetPlayer.Character then
            local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = targetPlayer.Character:FindFirstChild("Humanoid")
            if root and humanoid then
                if freeze then
                    root.Anchored = true
                    humanoid.WalkSpeed = 0
                    humanoid.JumpPower = 0
                else
                    root.Anchored = false
                    humanoid.WalkSpeed = 16
                    humanoid.JumpPower = 50
                end
            end
        end
    end)
end

-- Fungsi chat command listener
local function onPlayerChatted(player, message)
    -- Cek apakah admin
    if not isAdmin(player) then return end
    
    -- Parse command (bisa pake / atau !)
    if message:sub(1, 1) == "/" or message:sub(1, 1) == "!" then
        local parts = string.split(message, " ")
        local cmd = parts[1]:sub(2):lower()
        local targetName = parts[2]
        local reason = table.concat(parts, " ", 3)
        
        -- Cari target player
        local targetPlayer = nil
        if targetName then
            targetPlayer = Players:FindFirstChild(targetName)
            if not targetPlayer then
                -- Coba cari partial match
                for _, p in pairs(Players:GetPlayers()) do
                    if p.Name:lower():find(targetName:lower()) then
                        targetPlayer = p
                        break
                    end
                end
            end
        end
        
        -- Eksekusi command
        if cmd == "kick" and targetPlayer then
            kickPlayer(targetPlayer, reason)
        elseif cmd == "ban" and targetPlayer then
            banPlayer(targetPlayer, reason)
        elseif cmd == "tp" and targetPlayer then
            teleportToPlayer(targetPlayer)
        elseif cmd == "kill" and targetPlayer then
            killPlayer(targetPlayer)
        elseif cmd == "freeze" and targetPlayer then
            freezePlayer(targetPlayer, true)
        elseif cmd == "unfreeze" and targetPlayer then
            freezePlayer(targetPlayer, false)
        elseif cmd == "admin" then
            print("[ADMIN] Available commands: /kick, /ban, /tp, /kill, /freeze, /unfreeze")
        elseif cmd == "adminlist" then
            local adminList = "Admins: "
            for admin, _ in pairs(ADMINS) do
                adminList = adminList .. admin .. ", "
            end
            print(adminList)
        end
    end
end

