-- ==================== TOUCH KILL SCRIPT ====================
local touchKillScript = [[
--[[ TOUCH KILL (Instant on touch) ]]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local touchEnabled = false
local lastTouchTime = 0
local TOUCH_COOLDOWN = 0.01
local touchConnections = {}

local function instantKill(player)
    if not player or player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if hum then hum.Health = 0 end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then root.CFrame = CFrame.new(0, -500, 0) end
end

local function onTouch(part)
    if not touchEnabled then return end
    local now = tick()
    if now - lastTouchTime < TOUCH_COOLDOWN then return end
    lastTouchTime = now
    local otherChar = part:FindFirstAncestorOfClass("Model")
    if not otherChar then return end
    local player = Players:GetPlayerFromCharacter(otherChar)
    if player then instantKill(player) end
end

local function connectTouches()
    for _, conn in ipairs(touchConnections) do conn:Disconnect() end
    touchConnections = {}
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            local conn = part.Touched:Connect(onTouch)
            table.insert(touchConnections, conn)
        end
    end
end

LocalPlayer.CharacterAdded:Connect(function()
    if touchEnabled then task.wait(0.5); connectTouches() end
end)

