-- Scan backdoor function
local backdoors = {}
local function ScanBackdoor()
    backdoors = {}
    for _, obj in pairs(ReplicatedStorage:GetChildren()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            if obj.Name:lower():find("admin") or obj.Name:lower():find("kick") or obj.Name:lower():find("ban") or obj.Name:lower():find("execute") then
                table.insert(backdoors, obj)
            end
        end
    end
    if #backdoors > 0 then
        status.Text = "✅ " .. #backdoors .. " backdoor(s) found"
        status.TextColor3 = Color3.new(0,1,0)
    else
        status.Text = "❌ No backdoor found"
        status.TextColor3 = Color3.new(1,0,0)
    end
end
ScanBackdoor()

