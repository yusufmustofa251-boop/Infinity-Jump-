-- ===============================
-- BUTTON CREATOR (MODERN STYLE)
-- ===============================
local function createButton(parent,text,posY,callback)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(0.8,0,0.12,0)
    b.Position = UDim2.new(0.1,0,posY,0)
    b.Text = text
    b.BackgroundColor3 = Color3.fromRGB(35,35,35)
    b.TextColor3 = Color3.fromRGB(255,255,255)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 14

    -- ROUND
    local corner = Instance.new("UICorner", b)
    corner.CornerRadius = UDim.new(0,12)

    -- GLOW STROKE
    local stroke = Instance.new("UIStroke", b)
    stroke.Color = Color3.fromRGB(255,0,80)
    stroke.Thickness = 1.5

    -- HOVER EFFECT
    b.MouseEnter:Connect(function()
        b:TweenSize(UDim2.new(0.82,0,0.13,0),"Out","Quad",0.1,true)
        stroke.Color = Color3.fromRGB(255,80,120)
    end)
    b.MouseLeave:Connect(function()
        b:TweenSize(UDim2.new(0.8,0,0.12,0),"Out","Quad",0.1,true)
        stroke.Color = Color3.fromRGB(255,0,80)
    end)

    b.MouseButton1Click:Connect(callback)
    return b
end

