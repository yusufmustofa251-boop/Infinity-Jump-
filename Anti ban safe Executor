box.ClearTextOnFocus = false
box.TextXAlignment = Enum.TextXAlignment.Left
box.TextYAlignment = Enum.TextYAlignment.Top
box.BackgroundColor3 = Color3.fromRGB(25,25,25)
box.TextColor3 = Color3.fromRGB(200,200,200)
Instance.new("UICorner", box)

local function log(msg)
    local console = frame:FindFirstChild("Console")
    if not console then
        console = Instance.new("TextLabel", frame)
        console.Name = "Console"
        console.Size = UDim2.new(0.9,0,0.15,0)
        console.Position = UDim2.new(0.05,0,0.5,0)
        console.Text = ""
        console.TextColor3 = Color3.fromRGB(0,255,150)
        console.TextXAlignment = Enum.TextXAlignment.Left
        console.TextYAlignment = Enum.TextYAlignment.Top
        console.BackgroundTransparency = 1
    end
    console.Text = console.Text.."\n"..msg
end

createButton(frame,"EXECUTE",0.32,function()
    local code = box.Text
    table.insert(history, code)
    local success, err = pcall(function() loadstring(code)() end)
    if success then log("SUCCESS ✅") else log("ERROR ❌ "..err) end
end)

createButton(frame,"SAVE 💾",0.44,function()
    table.insert(savedScripts, box.Text)
    log("Saved #"..#savedScripts)
end)

createButton(frame,"HISTORY 📜",0.56,function()
    log("[ HISTORY ]")
    for i,v in pairs(history) do
        log("Script "..i..": "..v)
    end
end)

createButton(frame,"SAVED 📂",0.68,function()
    log("[ SAVED ]")
    for i,v in pairs(savedScripts) do
        log("Saved "..i..": "..v)
    end
end)

