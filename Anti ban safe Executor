-- ===============================
-- TELEPORT FEATURE
-- ===============================
local savedPos
local function playTeleportSound()
    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://9118823102"
    s.Volume = 2
    s.Parent = workspace
    s:Play()
    game.Debris:AddItem(s,3)
end

local function teleportEffect(char)
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local part = Instance.new("Part")
    part.Size = Vector3.new(2,2,2)
    part.Shape = Enum.PartType.Ball
    part.Material = Enum.Material.Neon
    part.Color = Color3.fromRGB(255,0,80)
    part.Anchored = true
    part.CanCollide = false
    part.CFrame = root.CFrame
    part.Parent = workspace

    local light = Instance.new("PointLight", part)
    light.Brightness = 10
    light.Range = 15
    light.Color = Color3.fromRGB(255,0,120)

    part:TweenSize(Vector3.new(10,10,10),"Out","Quad",0.3,true)

    local flash = Instance.new("ColorCorrectionEffect", game.Lighting)
    flash.TintColor = Color3.fromRGB(255,150,150)
    flash.Brightness = 0.5

    task.delay(0.6,function()
        flash:Destroy()
        part:Destroy()
    end)
end

local function notify(msg)
    local hint = Instance.new("Hint")
    hint.Text = msg
    hint.Parent = workspace
    game.Debris:AddItem(hint,2)
end

createButton(frame,"Save Position 📍",0.75,function()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if root then savedPos = root.CFrame end
end)

createButton(frame,"Teleport ⚡",0.87,function()
    local char = player.Character
    if savedPos and char then
        char:PivotTo(savedPos)
        playTeleportSound()
        teleportEffect(char)
        notify("Teleport Owner Has Active")
    end
end)

