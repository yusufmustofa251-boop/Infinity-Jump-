-- Notifikasi
local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 3
        })
    end)
end

notify("✅ ADMIN ACTIVE", "Welcome " .. LocalPlayer.Name, 5)

-- Fungsi Admin
local function isAdmin(p) return ADMINS[p.Name] end

local function kickPlayer(target)
    pcall(function() TeleportService:Teleport(6403373529, target) end)
    pcall(function() if target.Character then target.Character:BreakJoints() end end)
    notify("Kick", target.Name .. " kicked", 2)
end

local function banPlayer(target)
    BannedPlayers[target.Name] = {userId = target.UserId}
    kickPlayer(target)
    notify("Ban", target.Name .. " banned", 2)
end

local function tpToPlayer(target)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-3)
        end
    end
end

local function killPlayer(target)
    pcall(function() if target.Character then target.Character:BreakJoints() end end)
end

local function freezePlayer(target, freeze)
    pcall(function()
        if target.Character then
            local root = target.Character:FindFirstChild("HumanoidRootPart")
            local hum = target.Character:FindFirstChild("Humanoid")
            if root and hum then
                root.Anchored = freeze
                hum.WalkSpeed = freeze and 0 or 16
            end
        end
    end)
end

-- Chat Commands
local function onChat(player, msg)
    if not isAdmin(player) then return end
    if msg:sub(1,1) == "/" then
        local parts = string.split(msg, " ")
        local cmd = parts[1]:sub(2):lower()
        local target = Players:FindFirstChild(parts[2])
        
        if not target then
            for _,p in pairs(Players:GetPlayers()) do
                if p.Name:lower():find((parts[2] or ""):lower()) then target = p break end
            end
        end
        
        if cmd == "kick" and target then kickPlayer(target)
        elseif cmd == "ban" and target then banPlayer(target)
        elseif cmd == "tp" and target then tpToPlayer(target)
        elseif cmd == "kill" and target then killPlayer(target)
        elseif cmd == "freeze" and target then freezePlayer(target, true)
        elseif cmd == "unfreeze" and target then freezePlayer(target, false)
        elseif cmd == "admin" then print("Commands: /kick, /ban, /tp, /kill, /freeze, /unfreeze")
        end
    end
end

for _,p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) onChat(p,m) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) onChat(p,m) end) end)

