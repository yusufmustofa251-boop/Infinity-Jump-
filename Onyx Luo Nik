-- ================= VIP =================
local function vipMenu()
	clear()

	if not isVIP then
		local box = Instance.new("TextBox", content)
		box.Size = UDim2.new(0.6,0,0.15,0)
		box.Position = UDim2.new(0.2,0,0.2,0)
		box.PlaceholderText = "VIP PASSWORD"

		btn(content,"LOGIN",0.4,function()
			if box.Text == "VIPONLY" then
				isVIP = true
				vipMenu()
			end
		end)
	else
		local label = Instance.new("TextLabel", content)
		label.Size = UDim2.new(1,0,0.2,0)
		label.Text = "FreeVIP 👑"
		label.BackgroundTransparency = 1
		label.TextColor3 = Color3.fromRGB(255,0,80)

		btn(content,"Super Speed ⚡",0.3,function()
			states.speed = true
			apply()
		end)
	end
end

