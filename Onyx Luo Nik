-- ================= BUTTON GOD =================
local function btn(parent,text,y,func)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(0.85,0,0.12,0)
	b.Position = UDim2.new(0.075,0,y,0)
	b.Text = text
	b.BackgroundColor3 = Color3.fromRGB(40,40,40)
	b.TextColor3 = Color3.new(1,1,1)
	b.Font = Enum.Font.GothamBold

	local corner = Instance.new("UICorner", b)
	corner.CornerRadius = UDim.new(0,20)

	local stroke = Instance.new("UIStroke", b)
	stroke.Color = Color3.fromRGB(255,0,80)

	b.MouseEnter:Connect(function()
		b:TweenSize(UDim2.new(0.88,0,0.14,0),"Out","Quad",0.1,true)
	end)

	b.MouseLeave:Connect(function()
		b:TweenSize(UDim2.new(0.85,0,0.12,0),"Out","Quad",0.1,true)
	end)

	b.MouseButton1Click:Connect(function()
		b:TweenSize(UDim2.new(0.82,0,0.1,0),"Out","Quad",0.05,true)
		task.wait(0.05)
		b:TweenSize(UDim2.new(0.85,0,0.12,0),"Out","Quad",0.05,true)
		func()
	end)

	return b
end

-- ================= STATES =================
local states = {speed=false,jump=false,invisible=false}
local isVIP = false

local function apply()
	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChild("Humanoid")

	if hum then
		hum.WalkSpeed = states.speed and 80 or 16
		hum.JumpPower = states.jump and 100 or 50
	end

	for _,v in pairs(char:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Transparency = states.invisible and 0.7 or 0
		end
	end
end

player.CharacterAdded:Connect(function()
	task.wait(0.5)
	apply()
end)

-- ================= PLAYER =================
local function playerMenu()
	clear()

	btn(content,"Speed ⚡",0,function()
		states.speed = not states.speed
		apply()
	end)

	btn(content,"Jump 🦘",0.15,function()
		states.jump = not states.jump
		apply()
	end)

	btn(content,"Invisible 👻",0.3,function()
		states.invisible = not states.invisible
		apply()
	end)
end

-- ================= TELEPORT =================
local savedPos

local function teleportMenu()
	clear()

	btn(content,"Save 📍",0,function()
		local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if r then savedPos = r.CFrame end
	end)

	btn(content,"Teleport ⚡",0.2,function()
		local char = player.Character
		if savedPos and char then
			char:PivotTo(savedPos)
		end
	end)
end

