-- ==================== FUNCTIONS ====================
local function updateStatus(text, isError)
    statusLabel.Text = text
    statusLabel.TextColor3 = isError and Color3.new(1, 0, 0) or Color3.new(0, 255, 0)
end

local function executeScript(script)
    if not script or script == "" then
        updateStatus("❌ No script to execute", true)
        return
    end
    local success, err = pcall(function()
        loadstring(script)()
    end)
    if success then
        updateStatus("✅ Script executed successfully!", false)
    else
        updateStatus("❌ Error: " .. tostring(err):sub(1, 60), true)
    end
end

