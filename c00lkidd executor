aimbotBtn.MouseButton1Click:Connect(function()
    executeScript([[
        -- Aimbot + ESP (Rayfield)
        local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
        local Players = game:GetService("Players")
        local RunService = game:GetService("RunService")
        local LocalPlayer = Players.LocalPlayer
        local Camera = workspace.CurrentCamera
        
        local Settings = {
            Aimbot = { Enabled = false, Radius = 500, Smooth = 0.2, Part = "Head" },
            ESP = { Enabled = false }
        }
        
        local currentTarget = nil
        local espObjects = {}
        
        local function IsVisible(player)
            if not player or not player.Character then return false end
            local part = player.Character:FindFirstChild(Settings.Aimbot.Part) or player.Character:FindFirstChild("HumanoidRootPart")
            if not part then return false end
            local myChar = LocalPlayer.Character
            if not myChar then return false end
            local ray = Ray.new(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * 1000)
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {myChar, player.Character})
            return hit == nil
        end
        
        local function GetBestTarget()
            local myChar = LocalPlayer.Character
            if not myChar then return nil end
            local myRoot = myChar:FindFirstChild("HumanoidRootPart")
            if not myRoot then return nil end
            local best = nil
            local bestDist = math.huge
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local hum = player.Character:FindFirstChild("Humanoid")
                    if hum and hum.Health > 0 then
                        local root = player.Character:FindFirstChild("HumanoidRootPart")
                        if root then
                            local dist = (root.Position - myRoot.Position).Magnitude
                            if dist <= Settings.Aimbot.Radius and dist < bestDist then
                                bestDist = dist
                                best = player
                            end
                        end
                    end
                end
            end
            return best
        end
        
        RunService.RenderStepped:Connect(function()
            if Settings.Aimbot.Enabled then
                local target = GetBestTarget()
                currentTarget = target
                if target and target.Character then
                    local part = target.Character:FindFirstChild(Settings.Aimbot.Part) or target.Character:FindFirstChild("HumanoidRootPart")
                    if part then
                        local targetPos = part.Position
                        if Settings.Aimbot.Part == "Head" then targetPos = targetPos + Vector3.new(0,0.5,0)
                        local dir = (targetPos - Camera.CFrame.Position).Unit
                        local newCF = CFrame.lookAt(Camera.CFrame.Position, Camera.CFrame.Position + dir)
                        Camera.CFrame = Camera.CFrame:Lerp(newCF, Settings.Aimbot.Smooth)
                    end
                end
            end
        end)
        
        local function CreateESP(player)
            if espObjects[player] then
                for _, obj in pairs(espObjects[player]) do pcall(obj.Remove, obj) end
            end
            espObjects[player] = {
                Box = Drawing.new("Square"),
                Name = Drawing.new("Text"),
                Dist = Drawing.new("Text")
            }
            local e = espObjects[player]
            e.Box.Visible = false; e.Box.Thickness = 2; e.Box.Filled = false
            e.Name.Visible = false; e.Name.Center = true; e.Name.Outline = true; e.Name.Size = 16; e.Name.Color = Color3.new(1,1,1)
            e.Dist.Visible = false; e.Dist.Center = true; e.Dist.Outline = true; e.Dist.Size = 14; e.Dist.Color = Color3.new(1,1,0)
        end
        
        RunService.RenderStepped:Connect(function()
            if not Settings.ESP.Enabled then
                for _, data in pairs(espObjects) do
                    if data.Box then data.Box.Visible = false end
                    if data.Name then data.Name.Visible = false end
                    if data.Dist then data.Dist.Visible = false end
                end
                return
            end
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            for player, data in pairs(espObjects) do
                if not player or not player.Character then
                    if data.Box then data.Box.Visible = false end
                    if data.Name then data.Name.Visible = false end
                    if data.Dist then data.Dist.Visible = false end
                else
                    local root = player.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        local pos, on = Camera:WorldToViewportPoint(root.Position)
                        if on then
                            if data.Box then
                                data.Box.Visible = true
                                data.Box.Position = Vector2.new(pos.X-20, pos.Y-40)
                                data.Box.Size = Vector2.new(40,80)
                                data.Box.Color = player == currentTarget and Color3.new(0,1,0) or Color3.new(1,0,0)
                                data.Box.Thickness = (player == currentTarget) and 3 or 2
                            end
                            if data.Name then
                                data.Name.Visible = true
                                data.Name.Position = Vector2.new(pos.X, pos.Y-55)
                                data.Name.Text = player.Name
                            end
                            if data.Dist and myRoot then
                                data.Dist.Visible = true
                                data.Dist.Position = Vector2.new(pos.X, pos.Y+45)
                                data.Dist.Text = string.format("%.0f", (root.Position - myRoot.Position).Magnitude)
                            end
                        else
                            if data.Box then data.Box.Visible = false end
                            if data.Name then data.Name.Visible = false end
                            if data.Dist then data.Dist.Visible = false end
                        end
                    end
                end
            end
        end)
        
        Players.PlayerAdded:Connect(function(p) if p ~= LocalPlayer then CreateESP(p) end end)
        for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end
        
        local Window = Rayfield:CreateWindow({
            Name = "🎯 AIMBOT + ESP",
            LoadingTitle = "Loading...",
            LoadingSubtitle = "c00lkidd Edition",
            ConfigurationSaving = { Enabled = true, FolderName = "c00lkiddAimbot", FileName = "Settings" },
            KeySystem = false
        })
        
        local AimbotTab = Window:CreateTab("🎯 Aimbot", 4483362458)
        AimbotTab:CreateSection("Aimbot Settings")
        AimbotTab:CreateToggle({ Name = "Enable Aimbot", CurrentValue = false, Flag = "AimbotToggle", Callback = function(v) Settings.Aimbot.Enabled = v end })
        AimbotTab:CreateSlider({ Name = "Radius", Range = {100, 10000}, Increment = 100, Suffix = " studs", CurrentValue = 500, Flag = "Radius", Callback = function(v) Settings.Aimbot.Radius = v end })
        AimbotTab:CreateSlider({ Name = "Smoothness", Range = {0.05, 0.5}, Increment = 0.01, Suffix = "", CurrentValue = 0.2, Flag = "Smooth", Callback = function(v) Settings.Aimbot.Smooth = v end })
        AimbotTab:CreateDropdown({ Name = "Target Part", Options = {"Head", "HumanoidRootPart"}, CurrentOption = "Head", Flag = "Part", Callback = function(v) Settings.Aimbot.Part = v end })
        
        local ESPTab = Window:CreateTab("👁️ ESP", 4483362458)
        ESPTab:CreateSection("ESP Settings")
        ESPTab:CreateToggle({ Name = "Enable ESP", CurrentValue = false, Flag = "ESPToggle", Callback = function(v) Settings.ESP.Enabled = v end })
        ESPTab:CreateParagraph({ Title = "Warna Box", Content = "🟢 Hijau = Target | 🔴 Merah = Musuh" })
        
        Rayfield:Notify({ Title = "✅ Aimbot + ESP", Content = "Loaded!", Duration = 3 })
    ]])
end)

