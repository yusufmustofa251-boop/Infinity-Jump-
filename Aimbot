local Camera = workspace.CurrentCamera
local VirtualUser = game:GetService("VirtualUser")

local Settings = {
    Aimbot = { Enabled = false, Radius = 10000, Smooth = 0.1 },
    Triggerbot = { Enabled = false, Delay = 0.05 },
    ESP = { Enabled = false },
    KillAura = { Enabled = false, Radius = 500, Damage = 999999 },
    AutoSword = { Enabled = false, Cooldown = 0.1 },
    Speed = { Enabled = false, Value = 200 },
    InfinityJump = { Enabled = false },
    Fly = { Enabled = false },
    GodMode = { Enabled = false }
}

local CurrentTarget = nil
local CanShoot = false
local LastShot = 0
local LastKillAura = 0
local LastSword = 0
local ESPObjects = {}

local function IsVisible(player)
    if not player or not player.Character then return false end
    local head = player.Character:FindFirstChild("Head")
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    local target = head or root
    if not target then return false end
    local myChar = LocalPlayer.Character
    if not myChar then return false end
    local ray = Ray.new(Camera.CFrame.Position, (target.Position - Camera.CFrame.Position).Unit * 1000)
    local hit = workspace:FindPartOnRayWithIgnoreList(ray, {myChar, player.Character})
    return hit == nil
end

local function GetLockedTarget()
    if CurrentTarget and CurrentTarget.Character then
        local hum = CurrentTarget.Character:FindFirstChild("Humanoid")
        if hum and hum.Health > 0 then
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local targetRoot = CurrentTarget.Character:FindFirstChild("HumanoidRootPart")
            if myRoot and targetRoot then
                local dist = (targetRoot.Position - myRoot.Position).Magnitude
                if dist <= Settings.Aimbot.Radius then return CurrentTarget end
            end
        end
    end
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hum = player.Character:FindFirstChild("Humanoid")
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and root then
                local dist = (root.Position - myRoot.Position).Magnitude
                if dist <= Settings.Aimbot.Radius and IsVisible(player) then
                    return player
                end
            end
        end
    end
    return nil
end

RunService.RenderStepped:Connect(function()
    if not Settings.Aimbot.Enabled then CurrentTarget = nil; return end
    local target = GetLockedTarget()
    if target then
        CurrentTarget = target
        CanShoot = IsVisible(target)
        local targetPart = target.Character:FindFirstChild("Head") or target.Character:FindFirstChild("HumanoidRootPart")
        if targetPart then
            local targetPos = targetPart.Position + Vector3.new(0,0.5,0)
            local dir = (targetPos - Camera.CFrame.Position).Unit
            local smooth = Camera.CFrame.LookVector:Lerp(dir, Settings.Aimbot.Smooth)
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, Camera.CFrame.Position + smooth)
        end
    else
        CurrentTarget = nil; CanShoot = false
    end
end)

RunService.Heartbeat:Connect(function()
    if Settings.Triggerbot.Enabled and CanShoot and CurrentTarget then
        local now = tick()
        if now - LastShot >= Settings.Triggerbot.Delay then
            pcall(function() mouse1click(); VirtualUser:ClickButton1(Vector2.new(0,0)) end)
            LastShot = now
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not Settings.KillAura.Enabled then return end
    local now = tick()
    if now - LastKillAura < 0.1 then return end
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hum = player.Character:FindFirstChild("Humanoid")
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and root then
                local dist = (root.Position - myRoot.Position).Magnitude
                if dist <= Settings.KillAura.Radius then
                    hum.Health = hum.Health - Settings.KillAura.Damage
                end
            end
        end
    end
    LastKillAura = now
end)

local function CreateESP(player)
    if ESPObjects[player] then for _, obj in pairs(ESPObjects[player]) do pcall(obj.Remove, obj) end end
    ESPObjects[player] = {
        Box = Drawing.new("Square"),
        Name = Drawing.new("Text"),
        Status = Drawing.new("Text")
    }
    local e = ESPObjects[player]
    e.Box.Visible = false; e.Box.Thickness = 2; e.Box.Filled = false
    e.Name.Visible = false; e.Name.Center = true; e.Name.Outline = true; e.Name.Size = 16; e.Name.Color = Color3.new(1,1,1)
    e.Status.Visible = false; e.Status.Center = true; e.Status.Outline = true; e.Status.Size = 12
end

RunService.RenderStepped:Connect(function()
    if not Settings.ESP.Enabled then
        for _, data in pairs(ESPObjects) do
            if data.Box then data.Box.Visible = false end
            if data.Name then data.Name.Visible = false end
            if data.Status then data.Status.Visible = false end
        end
        return
    end
    for player, data in pairs(ESPObjects) do
        if not player or not player.Character then
            if data.Box then data.Box.Visible = false end
            if data.Name then data.Name.Visible = false end
            if data.Status then data.Status.Visible = false end
        else
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
                local visible = IsVisible(player)
                if onScreen then
                    if data.Box then
                        data.Box.Visible = true
                        data.Box.Position = Vector2.new(pos.X-20, pos.Y-40)
                        data.Box.Size = Vector2.new(40,80)
                        if player == CurrentTarget then
                            data.Box.Color = visible and Color3.new(0,1,0) or Color3.new(1,1,0)
                            data.Box.Thickness = 3
                        else
                            data.Box.Color = visible and Color3.new(0,1,0) or Color3.new(1,0,0)
                            data.Box.Thickness = 2
                        end
                    end
                    if data.Name then
                        data.Name.Visible = true
                        data.Name.Position = Vector2.new(pos.X, pos.Y-55)
                        data.Name.Text = player.Name
                    end
                    if data.Status and player == CurrentTarget then
                        data.Status.Visible = true
                        data.Status.Position = Vector2.new(pos.X, pos.Y-70)
                        data.Status.Text = visible and "🔴 TEMBAK!" or "🟡 TERTUTUP"
                        data.Status.Color = visible and Color3.new(1,0,0) or Color3.new(1,1,0)
                    end
                else
                    if data.Box then data.Box.Visible = false end
                    if data.Name then data.Name.Visible = false end
                    if data.Status then data.Status.Visible = false end
                end
            end
        end
    end
end)

Players.PlayerAdded:Connect(function(p) if p~=LocalPlayer then CreateESP(p) end end)
for _,p in pairs(Players:GetPlayers()) do if p~=LocalPlayer then CreateESP(p) end end

spawn(function() while task.wait() do
