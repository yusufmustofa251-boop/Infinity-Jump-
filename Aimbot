        local h = LocalPlayer.Character:FindFirstChild("Humanoid")
        if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)

local BV, BG
local function ToggleFly(e)
    if e then
        local c = LocalPlayer.Character
        if not c then return end
        local r = c:FindFirstChild("HumanoidRootPart")
        local h = c:FindFirstChild("Humanoid")
        if not r or not h then return end
        h.PlatformStand = true
        BV = Instance.new("BodyVelocity"); BV.Velocity = Vector3.new(0,0,0); BV.MaxForce = Vector3.new(4000,4000,4000); BV.Parent = r
        BG = Instance.new("BodyGyro"); BG.MaxTorque = Vector3.new(4000,4000,4000); BG.Parent = r
        spawn(function()
            while Settings.Fly do
                task.wait()
                if not r or not BV then break end
                local m = Vector3.new(0,0,0)
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then m = m + Camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then m = m - Camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then m = m - Camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then m = m + Camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then m = m + Vector3.new(0,1,0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then m = m + Vector3.new(0,-1,0) end
                BV.Velocity = m.Magnitude>0 and m.Unit*50 or Vector3.new(0,0,0)
                BG.CFrame = CFrame.new(r.Position, r.Position + Camera.CFrame.LookVector)
            end
        end)
    else
        if BV then BV:Destroy() end
        if BG then BG:Destroy() end
        BV,BG = nil,nil
        if LocalPlayer.Character then
            local h = LocalPlayer.Character:FindFirstChild("Humanoid")
            if h then h.PlatformStand = false end
        end
    end
end

spawn(function() while task.wait(0.1) do
    if Settings.GodMode.Enabled and LocalPlayer.Character then
        local h = LocalPlayer.Character:FindFirstChild("Humanoid")
        if h and h.Health>0 then h.Health = h.MaxHealth end
    end
end end)

