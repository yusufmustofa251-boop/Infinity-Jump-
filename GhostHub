                local jumpConn = UserInputService.JumpRequest:Connect(function()
                    if LocalPlayer.Character then
                        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
                        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
                    end
                end)
                features["InfiniteJump"] = jumpConn
            else
                if features["InfiniteJump"] then features["InfiniteJump"]:Disconnect() end
            end
        elseif name == "Walk Speed" then
            spawn(function()
                while mainToggles["Walk Speed"] do
                    task.wait(0.1)
                    if LocalPlayer.Character then
                        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
                        if hum then hum.WalkSpeed = walkSpeedValue end
                    end
                end
                if LocalPlayer.Character then
                    local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
                    if hum and hum.WalkSpeed == walkSpeedValue then hum.WalkSpeed = 16 end
                end
            end)
        elseif name == "Super Jump" then
            spawn(function()
                while mainToggles["Super Jump"] do
                    task.wait(0.1)
                    if LocalPlayer.Character then
                        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
                        if hum then hum.JumpPower = superJumpValue end
                    end
                end
                if LocalPlayer.Character then
                    local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
                    if hum and hum.JumpPower == superJumpValue then hum.JumpPower = 50 end
                end
            end)
