            if enabled then
                game:GetService("StarterGui").SetCore("ShiftLock", true)
            else
                game:GetService("StarterGui").SetCore("ShiftLock", false)
            end
        elseif name == "Spectator" then
            if enabled then
                local cam = workspace.CurrentCamera
                local part = Instance.new("Part")
                part.Anchored = true
                part.CanCollide = false
                part.Transparency = 1
                part.Parent = workspace
                part.CFrame = cam.CFrame
                cam.CameraType = Enum.CameraType.Scriptable
                cam.CFrame = part.CFrame
            else
                workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
            end
        elseif name == "Tall Character" then
            if enabled and LocalPlayer.Character then
                local char = LocalPlayer.Character
                for _, part in pairs(char:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.Size = part.Size * 1.5
                    end
                end
            end
        end
    end)
    
    colGhost = colGhost + 1
    if colGhost >= maxColsGhost then colGhost = 0 end
end

