            if enabled then
                TeleportService:Teleport(game.PlaceId, LocalPlayer)
            end
        elseif name == "Anti AFK" then
            spawn(function()
                while mainToggles["Anti AFK"] do
                    task.wait(60)
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton2(Vector2.new())
                end
            end)
        elseif name == "Goto Camera" then
            if enabled and LocalPlayer.Character then
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then root.CFrame = workspace.CurrentCamera.CFrame end
            end
        elseif name == "Goto Spawn" then
            if enabled then
                local spawn = workspace:FindFirstChild("SpawnLocation")
                if spawn and LocalPlayer.Character then
                    local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if root then root.CFrame = spawn.CFrame end
                end
            end
        elseif name == "Night" then
            if enabled then
                game:GetService("Lighting").ClockTime = 0
            else
                game:GetService("Lighting").ClockTime = 14
            end
        elseif name == "Day" then
            if enabled then
                game:GetService("Lighting").ClockTime = 14
            end
        end
    end
    
    col = col + 1
    if col >= maxCols then col = 0 end
end

