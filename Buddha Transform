-- Toggle Function ala Delta
local function makeToggle(text, y)
    local holder = Instance.new("Frame", frame)
    holder.Size = UDim2.new(1,-20,0,40)
    holder.Position = UDim2.new(0,10,0,y)
    holder.BackgroundTransparency = 1
    holder.ZIndex = 2

    local label = Instance.new("TextLabel", holder)
    label.Size = UDim2.new(0.6,0,1,0)
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextScaled = true
    label.ZIndex = 3

    local toggle = Instance.new("Frame", holder)
    toggle.Size = UDim2.new(0,50,0,25)
    toggle.Position = UDim2.new(1,-60,0.5,-12)
    toggle.BackgroundColor3 = Color3.fromRGB(40,40,40)
    toggle.ZIndex = 2

    local circle = Instance.new("Frame", toggle)
    circle.Size = UDim2.new(0,20,0,20)
    circle.Position = UDim2.new(0,3,0.5,-10)
    circle.BackgroundColor3 = Color3.fromRGB(150,150,150)
    circle.ZIndex = 4

    local state = false

    local function setToggle(on)
        state = on
        local goalPos = on and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)
        local goalColor = on and Color3.fromRGB(0,120,255) or Color3.fromRGB(150,150,150)
        TweenService:Create(circle, TweenInfo.new(0.2), {Position = goalPos, BackgroundColor3 = goalColor}):Play()
        toggle.BackgroundColor3 = on and Color3.fromRGB(0,60,100) or Color3.fromRGB(40,40,40)
    end

    local function onClick(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            setToggle(not state)
        end
    end
    holder.InputBegan:Connect(onClick)

    return {Set = setToggle, Get = function() return state end}
end

